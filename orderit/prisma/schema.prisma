generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  buyer
  vendor
  admin
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
}

model users {
  id          String       @id @default(uuid()) @db.Uuid
  email       String       @unique
  full_name   String?
  phone       String?
  role        Role         @default(buyer)
  avatar_url  String?
  created_at  DateTime     @default(now()) @db.Timestamptz

  vendorProfile vendor_profiles?
  products      products[]  @relation("VendorProducts")
  buyerOrders   orders[]    @relation("BuyerOrders")
  vendorOrders  orders[]    @relation("VendorOrders")
  reviews       reviews[]
  sentMessages  messages[]  @relation("SentMessages")
  receivedMessages messages[] @relation("ReceivedMessages")
  notifications notifications[]
  stockLogs     stock_logs[]
}

model vendor_profiles {
  id             String   @id @default(uuid()) @db.Uuid
  user_id        String   @unique @db.Uuid
  shop_name      String
  shop_description String?
  logo_url       String?
  banner_url     String?
  location       String?
  is_verified    Boolean  @default(false)
  rating         Decimal  @default("0") @db.Decimal(3, 2)
  total_sales    BigInt   @default(0)
  created_at     DateTime @default(now()) @db.Timestamptz

  user users @relation(fields: [user_id], references: [id])
}

model categories {
  id        String      @id @default(uuid()) @db.Uuid
  name      String
  slug      String      @unique
  icon      String?
  parent_id String?     @db.Uuid

  parent    categories? @relation("CategoryChildren", fields: [parent_id], references: [id])
  children  categories[] @relation("CategoryChildren")
  products  products[]

  @@index([parent_id])
}

model products {
  id             String      @id @default(uuid()) @db.Uuid
  vendor_id      String      @db.Uuid
  category_id    String?     @db.Uuid
  name           String
  description    String?
  price          Decimal     @db.Decimal(12, 2)
  compare_price  Decimal?    @db.Decimal(12, 2)
  images         String[]    @db.Text[]
  stock_quantity Int         @default(0)
  sku            String?     @unique
  is_active      Boolean     @default(true)
  rating         Decimal     @default("0") @db.Decimal(3, 2)
  review_count   Int         @default(0)
  created_at     DateTime    @default(now()) @db.Timestamptz

  vendor   users       @relation("VendorProducts", fields: [vendor_id], references: [id])
  category categories? @relation(fields: [category_id], references: [id])
  orderItems order_items[]
  reviews    reviews[]
  stockLogs stock_logs[]

  @@index([vendor_id])
  @@index([category_id])
  @@index([is_active])
  @@index([created_at])
}

model orders {
  id               String       @id @default(uuid()) @db.Uuid
  buyer_id         String       @db.Uuid
  vendor_id        String       @db.Uuid
  status           OrderStatus
  subtotal         Decimal      @db.Decimal(12, 2)
  delivery_fee     Decimal      @db.Decimal(12, 2) @default("0")
  total            Decimal      @db.Decimal(12, 2)
  payment_method   String
  payment_reference String?
  payment_status   String
  delivery_address Json?
  created_at       DateTime     @default(now()) @db.Timestamptz

  buyer     users       @relation("BuyerOrders", fields: [buyer_id], references: [id])
  vendor    users       @relation("VendorOrders", fields: [vendor_id], references: [id])
  orderItems order_items[]
  messages  messages[]

  @@index([buyer_id])
  @@index([vendor_id])
  @@index([status])
  @@index([created_at])
}

model order_items {
  id              String   @id @default(uuid()) @db.Uuid
  order_id        String   @db.Uuid
  product_id      String   @db.Uuid
  quantity        Int      @default(1)
  price_at_purchase Decimal @db.Decimal(12, 2)
  product_name    String
  product_image   String?

  order   orders   @relation(fields: [order_id], references: [id])
  product products @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@index([product_id])
}

model reviews {
  id         String   @id @default(uuid()) @db.Uuid
  product_id String   @db.Uuid
  buyer_id   String   @db.Uuid
  rating     Int      @db.SmallInt
  comment    String?
  created_at DateTime @default(now()) @db.Timestamptz

  product products @relation(fields: [product_id], references: [id])
  buyer   users     @relation(fields: [buyer_id], references: [id])

  @@index([product_id])
  @@index([buyer_id])
}

model messages {
  id          String   @id @default(uuid()) @db.Uuid
  sender_id   String   @db.Uuid
  receiver_id String   @db.Uuid
  order_id    String?  @db.Uuid
  content     String
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz

  sender   users  @relation("SentMessages", fields: [sender_id], references: [id])
  receiver users  @relation("ReceivedMessages", fields: [receiver_id], references: [id])
  order    orders? @relation(fields: [order_id], references: [id])

  @@index([sender_id])
  @@index([receiver_id])
}

model notifications {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  title      String
  body       String
  type       String?
  is_read    Boolean  @default(false)
  link       String?
  created_at DateTime @default(now()) @db.Timestamptz

  user users @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
}

model stock_logs {
  id            String   @id @default(uuid()) @db.Uuid
  product_id    String   @db.Uuid
  previous_qty  Int
  new_qty       Int
  changed_by    String   @db.Uuid
  changed_at    DateTime @default(now()) @db.Timestamptz

  product products @relation(fields: [product_id], references: [id])
  user    users    @relation(fields: [changed_by], references: [id])

  @@index([product_id])
  @@index([changed_by])
  @@index([changed_at])
}
